<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="780.0" prefWidth="380.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
   <children>
      <VBox prefHeight="780.0" prefWidth="380.0">
         <children>
            <HBox alignment="BOTTOM_RIGHT" prefHeight="100.0" prefWidth="79.0">
               <children>
                  <VBox alignment="TOP_RIGHT" prefHeight="181.0" prefWidth="241.0">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <children>
                        <ImageView fitHeight="96.0" fitWidth="106.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@Images/arrow.png" />
                           </image>
                        </ImageView>
                        <Label alignment="CENTER" prefHeight="40.0" prefWidth="120.0" text="Future " textOverrun="CLIP">
                           <font>
                              <Font size="28.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" prefHeight="40.0" prefWidth="120.0" text="Forecast">
                           <font>
                              <Font size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="cityInput" alignment="TOP_CENTER" onAction="#searchMethod" prefHeight="25.0" prefWidth="369.0" promptText="Enter a City Name Here" />
               </children>
               <opaqueInsets>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </opaqueInsets>
               <padding>
                  <Insets left="15.0" right="15.0" top="15.0" />
               </padding></HBox>
            <HBox prefHeight="201.0" prefWidth="260.0" style="-fx-background-color: #9b6b6b;">
               <VBox.margin>
                  <Insets left="60.0" right="60.0" />
               </VBox.margin>
               <children>
                  <VBox alignment="CENTER" prefHeight="201.0" prefWidth="261.0">
                     <children>
                        <Label fx:id="time" text="Time" textFill="WHITE">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <Label fx:id="city" text="City Name" textFill="WHITE">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <ImageView fitHeight="150.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Images/cloudy.png" />
                                 </image>
                              </ImageView>
                              <Label fx:id="temperature" text="Temp" textFill="WHITE">
                                 <font>
                                    <Font size="48.0" />
                                 </font>
                              </Label>
                           </children></HBox>
                        <Label fx:id="rainChance" text="Rain Chance" textFill="WHITE">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <Label fx:id="weather" text="Weather Desc" textFill="WHITE">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                     </children>
                     <HBox.margin>
                        <Insets top="10.0" />
                     </HBox.margin>
                  </VBox>
               </children></HBox>
            <HBox alignment="CENTER" prefHeight="107.0" prefWidth="350.0" style="-fx-background-color: #9b6b6b;">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="60.0" />
               </VBox.margin>
               <children>
                  <VBox alignment="CENTER" prefHeight="107.0" prefWidth="350.0">
                     <children>
                        <Label fx:id="tmrWeather" text="TIMES Weather in CITY Will Be :" textFill="WHITE">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="tmrWeatherForecast" alignment="CENTER" prefWidth="300.0" text="Detailed Forcast" textAlignment="CENTER" textFill="WHITE" wrapText="true">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #9b6b6b;">
               <children>
                  <Label fx:id="testTimeTemperature" text="FindMe" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button alignment="BOTTOM_RIGHT" layoutX="260.0" mnemonicParsing="false" onAction="#switchSeneFuture" prefHeight="174.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
   </children>
</AnchorPane>
